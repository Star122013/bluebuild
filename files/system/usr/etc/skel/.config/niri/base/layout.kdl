layout {
    always-center-single-column
    gaps 8
    center-focused-column "never"

    preset-column-widths {
        proportion 0.25
        proportion 0.5
        proportion 0.75
        proportion 1.0
    }

    preset-window-heights {
        proportion 0.2
        proportion 0.4
        proportion 0.5
        proportion 0.6
        proportion 0.8
        proportion 1.0
    }

    default-column-width {
        proportion 0.75
    }
}
