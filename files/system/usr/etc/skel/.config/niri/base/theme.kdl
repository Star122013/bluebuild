layout {
    focus-ring {
        active-color   "#89b4fa"
        inactive-color "#313244"
        urgent-color   "#f38ba8"
    }

    border {
        active-color   "#89b4fa"
        inactive-color "#313244"
        urgent-color   "#f38ba8"
    }

    shadow {
        color "#11111b70"
    }

    tab-indicator {
        active-color   "#89b4fa"
        inactive-color "#45475a"
        urgent-color   "#f38ba8"
    }

    insert-hint {
        color "#89b4fa80"
    }
}
